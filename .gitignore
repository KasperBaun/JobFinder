# .NET build output
bin/
obj/
*.user
*.suo
.vs/
[Dd]ebug/
[Rr]elease/
[Ll]og/
[Ll]ogs/

# IDE files
.vscode/
.idea/
*.swp

# Per-user state — skillsets, search criteria, runs, marks
# Anything personal lives under data/<email>/, never committed
data/

# Belt-and-suspenders for src/backend/config/ — committed examples only
src/backend/config/skillset.md
src/backend/config/portals.yml

# Frontend build outputs
src/frontend/node_modules/
src/frontend/dist/

# Playwright e2e — local installs and reports
src/tests/playwright/node_modules/
src/tests/playwright/test-results/
src/tests/playwright/playwright-report/

# Root tooling — npm script wrapper
node_modules/

# Local NuGet output from `npm run package`
pkg/

# Self-contained publish + Windows installer build output
publish/
installer/Output/

# Scratch
.tmp/

# Playwright browsers
.playwright/
