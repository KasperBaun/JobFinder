    {
      "id": 8,
      "name": "adzuna-dk",
      "displayName": "Adzuna DK",
      "type": "api",
      "enabled": false,
      "endpoint": "https://api.adzuna.com/v1/api/jobs/dk/search/1",
      "queryParams": {
        "app_id": "YOUR_APP_ID",
        "app_key": "YOUR_APP_KEY",
        "what": "software",
        "results_per_page": 50,
        "content-type": "application/json"
      },
      "responseMapping": {
        "items_path": "results",
        "id": "id",
        "title": "title",
        "company": "company.display_name",
        "location": "location.display_name",
        "description": "description",
        "url": "redirect_url",
        "posted_at": "created"
      },
      "rateLimitRps": 1.0,
      "notes": "Adzuna is a general-purpose job aggregator with Danish coverage (free plan, ~250 searches/day). Setup needs both an app_id and an app_key from https://developer.adzuna.com. Two-key configuration isn't supported from this page yet — leave this off until that's wired up."
    },
    {
      "id": 9,
      "name": "jobnet",
      "displayName": "Jobnet",
      "type": "api",
      "enabled": false,
      "endpoint": "https://job.jobnet.dk/CV/FindWork/Search",
      "queryParams": {
        "SearchString": "software engineer",
        "Country": "Danmark",
        "Offset": 0,
        "SortValue": "CreationDate"
      },
      "responseMapping": {
        "items_path": "JobPositionPostings",
        "id": "Id",
        "title": "Title",
        "company": "HiringOrgName",
        "location": "WorkPlaceCity",
        "description": "Description",
        "url_template": "https://job.jobnet.dk/CV/FindWork/Details/{Id}",
        "posted_at": "PostingCreated"
      },
      "rateLimitRps": 2.0,
      "notes": "Jobnet is the Danish public employment service's job site. They no longer offer free automated access — using it now requires a paid agreement with the STAR agency (spoc@star.dk). Leave this off unless you have arranged access."
    },
    {
      "id": 10,
      "name": "jobindex",
      "displayName": "Jobindex",
      "type": "manual",
      "enabled": false,
      "notes": "Jobindex doesn't allow automated access. To include its listings, run a search on jobindex.dk in your browser, export the results, and save the CSV in your data/imports/ folder named jobindex-*.csv. The file needs these columns: title, company, location, url, description, posted_at."
    },
